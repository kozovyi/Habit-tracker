{
  "$schema": "https://cdn.statically.io/gh/nguyenngoclongdev/cdn/main/schema/v10/terminal-keeper.json",
  "theme": "tribe",
  "active": "default",
  "activateOnStartup": true,
  "keepExistingTerminals": false,
  "sessions": {
    "default": [
      {
        "name": "app",
        "autoExecuteCommands": true,
        "icon": "project",
        "color": "terminal.ansiBrightMagenta",
        "focus": true,
        "commands": [
          ".venv/Scripts/activate;cd src; python manage.py runserver;"
        ]
      },
      {
        "name": "dev",
        "autoExecuteCommands": true,
        "icon": "code",
        "color": "terminal.ansiBlue",
        "commands": [
          ".venv/Scripts/activate; cd src; clear;"
        ]
      }
    ]
  }
}